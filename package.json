{
  "name": "maidsclaw",
  "version": "0.1.0",
  "description": "TypeScript+Bun agent engine with Rust native modules",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json --noEmit",
    "check:legacy-memory-surface": "bun test test/memory/legacy-literal-gate.test.ts",
    "check:sisyphus-docs": "bun run scripts/cleanup-sisyphus-docs.ts",
    "cleanup:sisyphus-docs": "bun run scripts/cleanup-sisyphus-docs.ts --apply",
    "test": "bun test",
    "start": "bun run src/index.ts",
    "check:native": "cargo check --manifest-path native/Cargo.toml",
    "cli": "bun run scripts/cli.ts"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "bun-types": "1.3.10",
    "typescript": "^5.3.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "postgres": "3.4.8"
  }
}
