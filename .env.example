# MaidsClaw V1 — Environment Variables
# Copy this file to .env and fill in your actual values

# Required: LLM Provider API Keys
ANTHROPIC_API_KEY=sk-ant-PLACEHOLDER
OPENAI_API_KEY=sk-PLACEHOLDER

# Optional: Server Configuration (defaults shown)
MAIDSCLAW_PORT=3000
MAIDSCLAW_HOST=localhost

# Optional: Storage Configuration (defaults shown)
MAIDSCLAW_DB_PATH=./data/maidsclaw.db
MAIDSCLAW_DATA_DIR=./data

# Optional: Native Modules (set to false to use TypeScript fallbacks)
MAIDSCLAW_NATIVE_MODULES=true
