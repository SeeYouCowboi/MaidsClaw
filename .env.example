# MaidsClaw V1 — Environment Variables
# Copy this file to .env and fill in your actual values.
# .env is gitignored — never commit real API keys.

# ─── LLM Provider API Keys ────────────────────────────────────────────────────

# Required: at least one chat provider must be set
ANTHROPIC_API_KEY=sk-ant-PLACEHOLDER
OPENAI_API_KEY=sk-PLACEHOLDER

# Optional providers (uncomment the ones you use; can also be configured via
# config/auth.json). The bailian key is REQUIRED if you use the default
# embedding model bailian/text-embedding-v4 (see Memory Pipeline below).
# BAILIAN_API_KEY=sk-...
# MOONSHOT_API_KEY=sk-...
# MINIMAX_API_KEY=sk-...
# KIMI_CODING_API_KEY=sk-kimi-...           # Tier B subscription
# OPENAI_CODEX_OAUTH_TOKEN=oa-...           # Tier C experimental
# ANTHROPIC_SETUP_TOKEN=stp-...             # Tier C experimental

# ─── Server Configuration ─────────────────────────────────────────────────────

# Port 18790 matches Maids-Dashboard's VITE_API_BASE
# (../Maids-Dashboard/.env.development). Override only if the dashboard is
# pointed elsewhere.
MAIDSCLAW_PORT=18790
MAIDSCLAW_HOST=localhost

# ─── Storage Configuration ────────────────────────────────────────────────────

# Legacy SQLite path (used by some maintenance scripts; PG is the primary backend)
MAIDSCLAW_DB_PATH=./data/maidsclaw.db
MAIDSCLAW_DATA_DIR=./data

# Set to false to disable native modules and use TypeScript fallbacks
MAIDSCLAW_NATIVE_MODULES=true

# ─── PostgreSQL (local PG 16 on port 55432) ──────────────────────────────────

# Job queue databases
JOBS_PG_URL=postgres://maidsclaw:maidsclaw@127.0.0.1:55432/maidsclaw_jobs
JOBS_PG_TEST_URL=postgres://maidsclaw:maidsclaw@127.0.0.1:55432/maidsclaw_jobs_test
PG_TEST_URL=postgres://maidsclaw:maidsclaw@127.0.0.1:55432/maidsclaw_jobs_test

# Main application database
PG_APP_URL=postgres://maidsclaw:maidsclaw@127.0.0.1:55432/maidsclaw_app

# Test database (separate from main to avoid test data pollution)
PG_APP_TEST_URL=postgres://maidsclaw:maidsclaw@127.0.0.1:55432/maidsclaw_app_test

# ─── Memory Pipeline ──────────────────────────────────────────────────────────

# REQUIRED for semantic episode/entity retrieval. Without this the
# graph-organizer never runs and node_embeddings stays empty — episode
# retrieval falls back to recency-only ordering with a flat baseline score
# (no semantic ranking). Format: <provider>/<model>
MAIDSCLAW_MEMORY_EMBEDDING_MODEL=bailian/text-embedding-v4

# Optional override: graph-organizer can use a different embedding model than
# the main retrieval path. Defaults to MAIDSCLAW_MEMORY_EMBEDDING_MODEL.
# MAIDSCLAW_MEMORY_ORGANIZER_EMBEDDING_MODEL=bailian/text-embedding-v4

# Optional: chat model for memory maintenance tasks (cognition extraction,
# settlement, evaluation). Defaults to TASK_AGENT_PROFILE.modelId
# (currently anthropic/claude-3-5-haiku-20241022).
# MAIDSCLAW_MEMORY_MIGRATION_MODEL=anthropic/claude-3-5-haiku-20241022

# ─── Query Routing & Retrieval Feature Flags (debug / shadow toggles) ────────

# All flags are optional. Defaults are "enabled". Set to the listed off-value
# to disable; useful for A/B tests, debugging, or rollback.

# Query router: =0 disables router entirely, falling back to legacy heuristics
# MAIDSCLAW_QUERY_ROUTER_SHADOW=0

# Query plan construction: =0 disables plan building
# MAIDSCLAW_QUERY_PLAN_SHADOW=0

# Plan consumption inside RetrievalService: =off falls back to legacy template path
# MAIDSCLAW_RETRIEVAL_USE_PLAN=off

# Plan consumption inside GraphNavigator
# MAIDSCLAW_NAVIGATOR_USE_PLAN=off

# Facet-based retrieval ranking
# MAIDSCLAW_RETRIEVAL_USE_FACETS=off

# Router signal toggles
# MAIDSCLAW_ROUTER_EPISODE_SIGNALS=off
# MAIDSCLAW_ROUTER_PRIVATE_ALIAS_SCAN=off

# ─── Misc ─────────────────────────────────────────────────────────────────────

# CJK segmenter (jieba). Default ON. Set to "off" to disable.
# MAIDSCLAW_CJK_SEGMENTER=off

# Trace capture for the Study panel's retrieval inspector. Default ON.
# Set to "off" to disable in-memory trace capture.
# MAIDSCLAW_TRACE_CAPTURE=off
