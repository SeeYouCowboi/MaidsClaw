# MaidsClaw V1 — Environment Variables
# Copy this file to .env and fill in your actual values

# Required: LLM Provider API Keys
ANTHROPIC_API_KEY=sk-ant-PLACEHOLDER
OPENAI_API_KEY=sk-PLACEHOLDER

# Optional: Server Configuration (defaults shown)
MAIDSCLAW_PORT=3000
MAIDSCLAW_HOST=localhost

# Optional: Storage Configuration (defaults shown)
MAIDSCLAW_DB_PATH=./data/maidsclaw.db
MAIDSCLAW_DATA_DIR=./data

# Optional: Native Modules (set to false to use TypeScript fallbacks)
MAIDSCLAW_NATIVE_MODULES=true

# Tier B: Kimi for Coding (subscription, use config/auth.json or env var)
# KIMI_CODING_API_KEY=sk-kimi-...

# Tier B: Moonshot Platform metered API (pay-per-token, use config/auth.json or env var)
# MOONSHOT_API_KEY=sk-...

# Tier B: MiniMax (OpenAI-compatible, use config/auth.json or env var)
# MINIMAX_API_KEY=...

# Tier C: OpenAI Codex OAuth token (Experimental; prefer config/auth.json)
# OPENAI_CODEX_OAUTH_TOKEN=oa-...

# Tier C: Anthropic Claude Pro/Max setup token (Experimental; prefer config/auth.json)
# ANTHROPIC_SETUP_TOKEN=stp-...
